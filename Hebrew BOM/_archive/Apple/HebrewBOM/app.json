{
  "expo": {
    "name": "Hebrew BOM — Interlinear",
    "slug": "HebrewBOM",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hebrewbom.interlinear",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
