        { "id": "v-patah",  "type": "mcq", "prompt": { "he": "בַ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "patah (a)" }, "choices": ["patah (a)","qamats (ā)","qibbuts (u)","holam (ō)"] },
        { "id": "v-tsere",  "type": "mcq", "prompt": { "he": "בֵ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "tsere (ē)" }, "choices": ["tsere (ē)","segol (e)","shureq (û)","holem (ō)"] },
        { "id": "v-segol",  "type": "mcq", "prompt": { "he": "בֶ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "segol (e)" }, "choices": ["segol (e)","tsere (ē)","hireq (i)","patah (a)"] },
        { "id": "v-hireq",  "type": "mcq", "prompt": { "he": "בִ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "hireq (i)" }, "choices": ["hireq (i)","holam (ō)","qamats (ā)","segol (e)"] },
