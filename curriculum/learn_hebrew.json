        { "id": "v-qibbuts","type":"mcq","prompt": { "he": "בֻ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "qibbuts (u)" }, "choices": ["qibbuts (u)","shureq (û)","segol (e)","hireq (i)"] },
        { "id": "v-shureq","type":"mcq","prompt": { "he": "בוּ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "shureq (û)" }, "choices": ["shureq (û)","holam (ō)","qibbuts (u)","qamats (ā)"] },
        { "id": "v-hateph-segol","type":"mcq","prompt": { "he": "אֱ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "ḥateph segol (ĕ)" }, "choices": ["ḥateph segol (ĕ)","segol (e)","shewa","tsere (ē)"] },
        { "id": "v-hateph-patah","type":"mcq","prompt": { "he": "אֲ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "ḥateph patah (ă)" }, "choices": ["ḥateph patah (ă)","patah (a)","qamats (ā)","shewa"] },
        { "id": "v-hateph-qamats","type":"mcq","prompt": { "he": "אֳ", "hint": "Name the vowel (ignore the consonant)." }, "answer": { "en": "ḥateph qamats (ŏ)" }, "choices": ["ḥateph qamats (ŏ)","holam (ō)","qamats (ā)","qibbuts (u)"] }
      ]
