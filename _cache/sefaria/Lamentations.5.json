ָֽאנוּ׃","עַל־זֶ֗ה הָיָ֤ה דָוֶה֙ לִבֵּ֔נוּ עַל־אֵ֖לֶּה חָשְׁכ֥וּ עֵינֵֽינוּ׃","עַ֤ל הַר־צִיּוֹן֙ שֶׁשָּׁמֵ֔ם שׁוּעָלִ֖ים הִלְּכוּ־בֽוֹ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>","אַתָּ֤ה יְהֹוָה֙ לְעוֹלָ֣ם תֵּשֵׁ֔ב כִּסְאֲךָ֖ לְד֥וֹר וָדֽוֹר׃","לָ֤מָּה לָנֶ֙צַח֙ תִּשְׁכָּחֵ֔נוּ תַּֽעַזְבֵ֖נוּ לְאֹ֥רֶךְ יָמִֽים׃","הֲשִׁיבֵ֨נוּ יְהֹוָ֤ה&thinsp;<small>׀</small>&thinsp;אֵלֶ֙יךָ֙ <span class=\"mam-kq\"><span class=\"mam-kq-k\">(ונשוב)</span> <span class=\"mam-kq-q\">[וְֽנָשׁ֔וּבָה]</span></span> חַדֵּ֥שׁ יָמֵ֖ינוּ כְּקֶֽדֶם׃","כִּ֚י אִם־מָאֹ֣ס מְאַסְתָּ֔נוּ קָצַ֥פְתָּ עָלֵ֖ינוּ עַד־מְאֹֽד׃"]}],"available_versions":[{"status":"locked","priority":3,"license":"CC-BY-NC","versionNotes":"<a href=\"https://purl.org/jps/rjps-preface\">Preface</a>\n<br><br>\n<a href=\"https://purl.org/jps/gender\">Notes on Gender in Translation</a>\n<br><br>\n<a href=\"https://purl.org/scholar/rjps-comm\">Commentary on Translation Choices in the JPS TANAKH (RJPS)</a>","formatAsPoetry":"","digitizedBySefaria":"","method":"","heversionSource":"","versionUrl":"","versionTitleInHebrew":"","versionNotesInHebrew":"","shortVersionTitle":"Revised JPS, 2023","shortVersionTitleInHebrew":"","extendedNotes":"","extendedNotesHebrew":"","purchaseInformationImage":"https://storage.googleapis.com/sefaria-physical-editions/JPS-Tanakh-Gender-Sensitive-Edition-Cover-300x450.jpg","purchaseInformationURL":"https://jps.org/books/the-jps-tanakh-gender-sensitive-edition/","hasManuallyWrappedRefs":"","language":"en","title":"Lamentations","versionSource":"https://jps.org/books/the-jps-tanakh-gender-sensitive-edition/","versionTitle":"THE JPS TANAKH: Gender-Sensitive Edition","actualLanguage":"en","languageFamilyName":"english","isSource":false,"isPrimary":false,"direction":"ltr"},{"status":"locked","priority":2,"license":"CC-BY-SA","versionNotes":"<i>Miqra According to the Masorah</i> (MAM) is a digital Hebrew edition of the Tanakh based on the Aleppo Codex and related manuscripts. It is designed for readers, and 